# Astromedia frontend — public (versioned). DO NOT put real secrets here.

# URL the apiClient hits. In dev, leave as "/api" so Vite proxies to the backend.
# In prod set to your deployed backend, e.g. https://api.astromedia.app/api
VITE_BACKEND_URL=/api

# In dev, where Vite forwards "/api/*" calls (see vite.config.ts).
VITE_BACKEND_TARGET=http://localhost:8080

# Shared secret with the backend (must match ASTROMEDIA_PROXY_KEY on the server).
# Defense-in-depth: even with a valid JWT, requests need this header.
VITE_BACKEND_PROXY_KEY=replace-me-with-the-same-value-as-backend

# ─── Supabase Auth ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
