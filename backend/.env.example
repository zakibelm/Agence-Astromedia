# Astromedia Backend — environment variables

# ─── Server ──────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Redis (BullMQ) ──────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── Proxy auth (shared secret between frontend and backend) ─────
# Generate locally with: openssl rand -hex 32
ASTROMEDIA_PROXY_KEY=replace-me-with-random-32-byte-hex

# ─── Upstream secrets — NEVER ship these to the frontend ─────────
OPENROUTER_API_KEY=sk-or-...replace-me
BLOTATO_API_KEY=blt_...replace-me
DEFAULT_TEXT_MODEL=google/gemini-2.0-flash-001

# ─── Blotato config ──────────────────────────────────────────────
BLOTATO_API_URL=https://backend.blotato.com/v2
BLOTATO_VIDEO_MODEL=kwaivgi/kling-v3.0-pro
BLOTATO_VIDEO_MODEL_FALLBACK=minimax/hailuo-2.3

# ─── Database (Prisma) ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/astromedia?schema=public

# ─── OpenTelemetry ───────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=astromedia-backend

# ─── Webhook signature (Blotato) ─────────────────────────────────
WEBHOOK_SECRET=replace-me-with-blotato-webhook-secret

# ─── Supabase Auth (JWT verification) ────────────────────────────
# Modern projects use asymmetric signing (ES256/RS256) — only SUPABASE_URL needed.
# The backend fetches the public key from <URL>/auth/v1/.well-known/jwks.json.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Optional: legacy HS256 secret. Only set during the ~1h migration window
# when tokens issued before the asymmetric switch are still valid.
# After all legacy tokens expire, you can revoke this in the Supabase dashboard.
SUPABASE_JWT_SECRET=
